# Dashboard Summary Route
@api_router.get("/dashboard-summary")
async def get_dashboard_summary():
    # Get counts and summary data for the dashboard
    total_mechanics = await db.game_mechanics.count_documents({})
    completed_mechanics = await db.game_mechanics.count_documents({"status": ProjectStatus.COMPLETED})
    
    total_roadmap_items = await db.roadmap.count_documents({})
    completed_roadmap_items = await db.roadmap.count_documents({"status": ProjectStatus.COMPLETED})
    
    total_concept_art = await db.concept_art.count_documents({})
    team_members_count = await db.team_members.count_documents({})
    
    # Calculate overall progress
    roadmap_items = await db.roadmap.find().to_list(1000)
    if roadmap_items:
        avg_progress = sum(item.get("progress", 0) for item in roadmap_items) / len(roadmap_items)
    else:
        avg_progress = 0
    
    return {
        "project_name": "WitchCraft: Sorcerers and Nahuals",
        "overview": {
            "total_mechanics": total_mechanics,
            "completed_mechanics": completed_mechanics,
            "mechanics_progress": (completed_mechanics / total_mechanics * 100) if total_mechanics > 0 else 0,
            "total_roadmap_items": total_roadmap_items,
            "completed_roadmap_items": completed_roadmap_items,
            "roadmap_progress": (completed_roadmap_items / total_roadmap_items * 100) if total_roadmap_items > 0 else 0,
            "overall_progress": avg_progress,
            "total_concept_art": total_concept_art,
            "team_size": team_members_count,
        },
        "last_updated": datetime.utcnow()
    }


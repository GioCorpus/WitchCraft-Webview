@api_router.put("/roadmap/{item_id}/progress", response_model=RoadmapItem)
async def update_roadmap_progress(item_id: str, progress: int):
    if progress < 0 or progress > 100:
        raise HTTPException(status_code=400, detail="Progress must be between 0 and 100")
    
    item = await db.roadmap.find_one({"id": item_id})
    if not item:
        raise HTTPException(status_code=404, detail="Roadmap item not found")
    
    # Auto-update status based on progress
    new_status = ProjectStatus.COMPLETED if progress == 100 else ProjectStatus.IN_DEVELOPMENT
    
    await db.roadmap.update_one(
        {"id": item_id}, 
        {"$set": {"progress": progress, "status": new_status}}
    )
    
    updated_item = await db.roadmap.find_one({"id": item_id})
    return RoadmapItem(**updated_item)


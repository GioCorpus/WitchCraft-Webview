from fastapi import FastAPI, APIRouter, HTTPException
from dotenv import load_dotenv
from starlette.middleware.cors import CORSMiddleware
from motor.motor_asyncio import AsyncIOMotorClient
import os
import logging
from pathlib import Path
from pydantic import BaseModel, Field
from typing import List, Optional, Dict, Any
import uuid
from datetime import datetime
from enum import Enum


ROOT_DIR = Path(__file__).parent
load_dotenv(ROOT_DIR / '.env')

# MongoDB connection
mongo_url = os.environ['MONGO_URL']
client = AsyncIOMotorClient(mongo_url)
db = client[os.environ['DB_NAME']]

# Create the main app without a prefix
app = FastAPI(title="WitchCraft: Sorcerers and Nahuals - Game Documentation Portal")

# Create a router with the /api prefix
api_router = APIRouter(prefix="/api")

# Enums
class ProjectStatus(str, Enum):
    PLANNING = "planning"
    IN_DEVELOPMENT = "in_development"
    TESTING = "testing"
    COMPLETED = "completed"
    ON_HOLD = "on_hold"

class TeamRole(str, Enum):
    LEAD_PROGRAMMER = "lead_programmer"
    GAME_DESIGNER = "game_designer"
    TECHNICAL_ARTIST = "technical_artist"
    LEAD_3D_ARTIST = "lead_3d_artist"
    CONCEPT_ARTIST = "concept_artist"
    NARRATIVE_DESIGNER = "narrative_designer"
    COMPOSER = "composer"
    PROJECT_MANAGER = "project_manager"

class Priority(str, Enum):
    LOW = "low"
    MEDIUM = "medium"
    HIGH = "high"
    CRITICAL = "critical"

# Define Models for WitchCraft Game Documentation

# Game Technical Specifications
class TechnicalSpecs(BaseModel):
    id: str = Field(default_factory=lambda: str(uuid.uuid4()))
    title: str
    engine: str = "Unreal Engine 5"
    version: str = "5.4"
    platforms: List[str]
    features: Dict[str, Any]
    requirements: Dict[str, Any]
    updated_at: datetime = Field(default_factory=datetime.utcnow)

# Game Mechanics
class GameMechanic(BaseModel):
    id: str = Field(default_factory=lambda: str(uuid.uuid4()))
    name: str
    description: str
    category: str  # combat, transformation, progression, etc.
    implementation_details: str
    priority: Priority
    status: ProjectStatus
    created_at: datetime = Field(default_factory=datetime.utcnow)

# Concept Art and Assets
class ConceptArt(BaseModel):
    id: str = Field(default_factory=lambda: str(uuid.uuid4()))
